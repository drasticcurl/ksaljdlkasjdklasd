{
  // Configuracion de TypeScript para el subproyecto Remotion.
  // Basada en la plantilla recomendada por Remotion para proyectos con React + JSX.
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "types": ["node"]
  },
  "include": ["src", "render.mjs", "remotion.config.ts"],
  "exclude": ["node_modules", "out"]
}
